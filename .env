# ==========================================
# 🔐 SAFE PUBLIC .ENV (NO SECRETS INSIDE)
# ==========================================

# --- 1. TARGET TRADING ---
# Simbol utama yang digunakan bot (pastikan ada di Market Watch MT5)
SYMBOL="XAUUSDm"

# Timeframe analisa dalam menit
TIMEFRAME_MINUTES=15


# --- 2. KONEKSI METATRADER 5 ---
# Login akun MT5 (KOSONGKAN untuk public)
MT5_LOGIN=

# Password akun MT5 (KOSONGKAN)
MT5_PASSWORD=

# Server broker MT5 (Exness / lainnya)
MT5_SERVER=

# Lokasi file terminal MetaTrader 5 di komputer lo (opsional)
MT5_PATH=""


# --- 3. MODE EKSEKUSI BOT ---
# Jika True → bot berjalan tanpa benar-benar open trade
DRY_RUN=False

# Mode trading (SCALPING_M1 / SWING_M15 / TREND_H1)
TRADING_MODE="SWING_M15"


# --- 4. MANAJEMEN RISIKO ---
# Persentase risiko per trade (misal 1.0 = 1%)
RISK_PER_TRADE_PCT=1.0

# Batas kerugian harian (contoh 3% equity)
MAX_DAILY_DRAWDOWN_PCT=3.0

# Maksimal posisi aktif bersamaan
MAX_OPEN_TRADES=5


# --- 5. OTAK AI (DEEPSEEK + QWEN + GEMINI) ---
# Gunakan Gemini untuk analisa sentimen / evaluasi?
USE_GEMINI_FOR_SENTIMENT=true


# === API KEY (KOSONGKAN UNTUK PUBLIC) ===
# Primary DeepSeek / MegaLLM Key
DEEPSEEK_API_KEY=""

# URL API DeepSeek / MegaLLM
DEEPSEEK_BASE_URL="https://ai.megallm.io/v1"

# Model default fallback
DEEPSEEK_MODEL="gpt-4o-mini"


# === MODEL AI YANG DIGUNAKAN DALAM "COUNCIL" ===
# DeepSeek sebagai "Risk Manager"
MODEL_DEEPSEEK="deepseek-ai/deepseek-v3.1"

# Qwen sebagai "Strategist"
MODEL_QWEN="qwen/qwen3-next-80b-a3b-instruct"

# Gemini sebagai "Evaluator"
MODEL_EVALUATOR="gemini-2.0-flash"


# === GOOGLE GEMINI FALLBACK ===
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"


# === LEGACY OPENAI (SUDAH TIDAK DIGUNAKAN) ===
OPENAI_API_KEY=""


# --- 6. TEKNIKAL TIUNING ---
# Confidence minimal untuk entry
TECH_CONF_THRESHOLD=0.20

# Delay loop (detik)
LOOP_SLEEP_SECONDS=20

# Minimal jumlah candlestick untuk analisa
MIN_BARS_REQUIRED=200
